{
  "name": "flowingink-blog-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=@flowingink/web",
    "build": "turbo run build --filter=@flowingink/web",
    "preview": "pnpm --filter @flowingink/web preview",
    "test": "turbo run test --filter=@flowingink/web",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}